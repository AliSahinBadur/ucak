{
   "action": {
      "default_icon": "icon.png",
      "default_popup": "popup.html"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "all_frames": true,
      "js": [ "firefox_login_handler.js" ],
      "matches": [ "https://*.defensx.com/*", "https://*.defensx.dev/*" ],
      "run_at": "document_start"
   }, {
      "all_frames": false,
      "js": [ "isoolate_token.js" ],
      "matches": [ "https://*.defensx.com/*", "https://*.defensx.dev/*" ],
      "run_at": "document_end"
   }, {
      "all_frames": false,
      "js": [ "inject.js" ],
      "matches": [ "http://*/*", "https://*/*" ],
      "run_at": "document_start"
   }, {
      "all_frames": false,
      "js": [ "passwordless.js" ],
      "matches": [ "http://*/*", "https://*/*" ],
      "run_at": "document_start"
   }, {
      "all_frames": true,
      "css": [ "credentials.css" ],
      "exclude_matches": [ "https://*.defensx.com/*", "https://*.defensx.dev/*", "https://*.browserbench.org/*" ],
      "js": [ "credentials.js" ],
      "matches": [ "http://*/*", "https://*/*" ],
      "run_at": "document_start"
   }, {
      "all_frames": true,
      "exclude_matches": [ "http://localhost/*", "https://*.defensx.com/*", "https://*.defensx.dev/*" ],
      "js": [ "upload.js" ],
      "matches": [ "http://*/*", "https://*/*" ],
      "run_at": "document_start"
   }, {
      "all_frames": false,
      "exclude_matches": [ "http://localhost/*", "https://*.defensx.com/*", "https://*.defensx.dev/*" ],
      "js": [ "read_only.js" ],
      "matches": [ "http://*/*", "https://*/*" ],
      "run_at": "document_start"
   }, {
      "all_frames": true,
      "js": [ "adb.js" ],
      "matches": [ "https://canyoublockit.com/*" ],
      "run_at": "document_start"
   }, {
      "all_frames": true,
      "exclude_matches": [ "http://localhost/*", "https://localhost/*" ],
      "js": [ "print.js" ],
      "matches": [ "http://*/*", "https://*/*" ],
      "run_at": "document_start"
   }, {
      "all_frames": true,
      "exclude_matches": [ "http://localhost/*", "https://localhost/*" ],
      "js": [ "watermark.js" ],
      "matches": [ "http://*/*", "https://*/*" ],
      "run_at": "document_start"
   }, {
      "all_frames": true,
      "js": [ "pii.js" ],
      "matches": [ "http://*/*", "https://*/*" ],
      "run_at": "document_start"
   }, {
      "all_frames": true,
      "js": [ "noise_maker.js" ],
      "matches": [ "http://*/*", "https://*/*" ],
      "run_at": "document_start"
   }, {
      "all_frames": false,
      "js": [ "statusline.js" ],
      "matches": [ "https://*.chatgpt.com/*", "https://*.claude.ai/*", "https://gemini.google.com/*", "https://m365.cloud.microsoft/chat*", "https://copilot.microsoft.com/*" ],
      "run_at": "document_start"
   }, {
      "all_frames": false,
      "js": [ "chatgpt.js" ],
      "matches": [ "https://*.chatgpt.com/*" ],
      "run_at": "document_start"
   }, {
      "all_frames": false,
      "js": [ "mscopilot.js" ],
      "matches": [ "https://m365.cloud.microsoft/chat*", "https://copilot.microsoft.com/*" ],
      "run_at": "document_start"
   }, {
      "all_frames": true,
      "exclude_matches": [ "http://localhost/*", "https://localhost/*" ],
      "js": [ "input_blocker.js" ],
      "matches": [ "http://*/*", "https://*/*" ],
      "run_at": "document_start"
   }, {
      "all_frames": false,
      "exclude_matches": [ "https://*.claude.ai/logout*", "https://*.claude.ai/login*", "https://*.claude.ai/magic-link*" ],
      "js": [ "ai_protection.js" ],
      "matches": [ "https://*.chatgpt.com/*", "https://*.claude.ai/*" ],
      "run_at": "document_start"
   }, {
      "all_frames": true,
      "exclude_matches": [ "http://localhost/*" ],
      "js": [ "policy_emitter.js" ],
      "matches": [ "http://*/*", "https://*/*" ],
      "run_at": "document_start"
   } ],
   "content_security_policy": {
      "extension_pages": "script-src 'self' 'wasm-unsafe-eval';"
   },
   "description": "DefensX Platform Plugin",
   "externally_connectable": {
      "matches": [ "*://localhost/*", "https://*.defensx.com/*", "https://*.defensx.dev/*", "https://*.defensx.io/*" ]
   },
   "host_permissions": [ "\u003Call_urls>" ],
   "icons": {
      "128": "icon.png",
      "16": "icon.png",
      "48": "icon.png"
   },
   "incognito": "split",
   "key": "",
   "manifest_version": 3,
   "name": "DefensX",
   "permissions": [ "webNavigation", "webRequest", "webRequestBlocking", "storage", "downloads", "tabs", "management", "unlimitedStorage", "scripting", "idle", "alarms", "offscreen", "downloads.shelf", "downloads.ui", "bookmarks" ],
   "storage": {
      "managed_schema": "schema.json"
   },
   "update_url": "https://cloud.defensx.com/extensions/check",
   "version": "4.3.202",
   "web_accessible_resources": [ {
      "matches": [ "*://*/*" ],
      "resources": [ "info.html", "credentials.html", "training.html", "home.html", "consent.html", "download.html", "isoolate.js", "token.js", "icon.png", "logo-black-full.png", "thumb_up.svg", "thumb_down.svg", "upload_inject.js", "dx_world_context_reader.js", "mscopilot_helpers.js", "icon_readonly.png", "request_debugger_panel.html" ]
   } ]
}
